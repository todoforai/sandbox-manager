# Schema reference. Copy to .env or .env.development and fill in values.

DRAGONFLY_URL=redis://:<password>@<host>:<port>
NOISE_LOCAL_PRIVATE_KEY=<32-byte hex, generate via `cargo run -- keygen`>

BIND_ADDR=0.0.0.0:9000
NOISE_BIND_ADDR=0.0.0.0:9010

RUST_LOG=sandbox_manager=info

# Required — used to mint enroll tokens that the VM's bridge redeems on boot.
BACKEND_URL=
BACKEND_ADMIN_API_KEY=

# Optional — tell VMs to talk to a non-prod backend. Without these, bridge
# falls back to its compiled defaults (api.todofor.ai). Set both for
# localhost dev or any custom backend deployment.
#   ADDR        : <host>:<port> reachable from inside the VM, used for both
#                 Noise login (port 14100) and the bridge runtime WS (port
#                 derived as host:4000 by /init). Host is typically 10.0.0.1
#                 (the br-sandbox gateway as seen from the VM).
#   PUBLIC_KEY  : 32-byte hex matching the backend's NOISE_LOCAL_PRIVATE_KEY.
# MMDS_NOISE_BACKEND_ADDR=10.0.0.1:14100
# MMDS_NOISE_BACKEND_PUBKEY=<32-byte hex of backend's noise pubkey>
