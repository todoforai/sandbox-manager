# Schema reference. Copy to .env or .env.development and fill in values.

DRAGONFLY_URL=redis://:<password>@<host>:<port>
NOISE_LOCAL_PRIVATE_KEY=<32-byte hex, generate via `cargo run -- keygen`>

BIND_ADDR=0.0.0.0:9000
NOISE_BIND_ADDR=0.0.0.0:9010

RUST_LOG=sandbox_manager=info

# Required — used to mint enroll tokens that the VM's bridge redeems on boot.
BACKEND_URL=
BACKEND_ADMIN_API_KEY=
