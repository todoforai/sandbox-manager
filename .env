# Production config. Loaded when NODE_ENV=production.
# Committed alongside backend/.env (same convention).

DRAGONFLY_URL=__DRAGONFLY_URL__

NOISE_LOCAL_PRIVATE_KEY=__NOISE_LOCAL_PRIVATE_KEY__

BIND_ADDR=0.0.0.0:8200
ADMIN_BIND_ADDR=127.0.0.1:8210
NOISE_BIND_ADDR=0.0.0.0:8220

# Bearer for /admin/api/* on the loopback admin socket (defense-in-depth on top
# of the 127.0.0.1 bind). When unset, the admin REST refuses every request.
SANDBOX_MANAGER_ADMIN_KEY=__SANDBOX_MANAGER_ADMIN_KEY__

RUST_LOG=sandbox_manager=info

BACKEND_URL=https://api.todofor.ai
BACKEND_ADMIN_API_KEY=__BACKEND_ADMIN_API_KEY__
